
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"
          rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap"
          rel="stylesheet" />
    <!-- MDB -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/6.4.1/mdb.min.css"
          rel="stylesheet" />
    <link href="~/Content/facultyLogin.css" rel="stylesheet" />
    <title>Faculty-Login</title>
</head>
<body>
    <style>
        .loading-container {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: white;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }

        .loading-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-top: -80px;
        }

            .loading-wrapper img {
                width: 200px;
                height: 200px;
                margin-bottom: 10px;
            }
             button{
            background-color: #24b930 !important;
        }
    </style>

    <!---Loading-->
    <div class="loading-container">
        <div class="loading-wrapper">
            <img src="~/App_File/Image/gear.gif" />
            <i style="margin: -30px;">Please wait while we setting up for you. . .</i>
        </div>
    </div>
    <section class="vh-100">
        <div class="container-fluid h-custom">
            <div class="row d-flex justify-content-center align-items-center h-100">
                <div class="col-md-9 col-lg-6 col-xl-5">
                    @*<img src="https://mdbcdn.b-cdn.net/img/Photos/new-templates/bootstrap-login-form/draw2.webp"
                         class="img-fluid" alt="Sample image">*@
                    <img src="~/App_File/Image/facultyLogo.png"  class="img-fluid"/>
                </div>
                <div class="col-md-8 col-lg-6 col-xl-4 offset-xl-1">
                    <form method="post" id="formLogin">
                        <div class="d-flex flex-row align-items-center justify-content-center justify-content-lg-start">
                            <p class="lead fw-normal mb-0 me-3">Sign in with</p>
                            <button type="button" class="btn btn-primary btn-floating mx-1">
                                <i class="fab fa-facebook-f"></i>
                            </button>

                            <button type="button" class="btn btn-primary btn-floating mx-1">
                                <i class="fab fa-twitter"></i>
                            </button>

                            <button type="button" class="btn btn-primary btn-floating mx-1">
                                <i class="fab fa-linkedin-in"></i>
                            </button>
                        </div>

                        <div class="divider d-flex align-items-center my-4">
                            <p class="text-center fw-bold mx-3 mb-0">Or</p>
                        </div>

                        <div style="display: none;" id="loginLoading">
                            <img src="~/App_File/Image/gear.gif" height="50" width="50" /> Please wait...
                        </div>
                        <div class="alert alert-danger" id="errorLabel" style="display: none;">
                            username and password not match!
                        </div>
                        <!-- username input -->
                        <div class="form-outline mb-4">
                            <input type="text" id="fUser" class="form-control form-control-lg"
                                   placeholder="Enter username" name="faculty_username"/>
                            <label class="form-label" for="fUser">Username</label>
                        </div>

                        <!-- Password input -->
                        <div class="form-outline mb-3">
                            <input type="password" id="fPass" class="form-control form-control-lg"
                                   placeholder="Enter password" name="faculty_password"/>
                            <label class="form-label" for="fPass">Password</label>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <!-- Checkbox -->
                            <div class="form-check mb-0">
                                <input class="form-check-input me-2" type="checkbox" value="" id="adminLoginCheckbox" />
                                <label class="form-check-label" for="form2Example3">
                                    Login as Admin
                                </label>
                            </div>
                            <a href="#!" class="text-body">Forgot password?</a>
                        </div>

                        <div class="text-center text-lg-start mt-4 pt-2">
                            <button type="button" class="btn btn-primary btn-lg"
                                    style="padding-left: 2.5rem; padding-right: 2.5rem;" id="btnLogin">
                                Login
                            </button>
                            <p class="small fw-bold mt-2 pt-1 mb-0">
                                Don't have an account? <a href="@Url.Action("Register","Faculty")"
                                                          class="link-danger">Register</a>
                            </p>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </section>

    <script src="~/Scripts/jquery-1.10.2.min.js"></script>
    <script type="text/javascript"
            src="https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/6.4.1/mdb.min.js"></script>
    <script src="~/Scripts/Faculty/login.js"></script>
    <script>
        loadingScreen();
        function loadingScreen() {
            window.addEventListener('load', () => {
                document.querySelector('.loading-container').style.display = 'none';
            });
        }
    </script>
</body>
</html>
